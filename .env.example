# =========================================================================
# YieldAgent v2 environment
# =========================================================================
#
# Copy to `.env` (git-ignored) and fill in real values.
# Never commit real private keys or API credentials.

# --- Deployer / Agent wallet private key ---------------------------------
# 64 hex chars, with or without 0x prefix
PRIVATE_KEY=your_private_key_here

# Optional separate agent address (defaults to deployer address)
AGENT_ADDRESS=

# --- X Layer RPC ---------------------------------------------------------
# Mainnet chainId 196, testnet chainId 1952.
# Flip CHAIN_ID below to switch which RPC the agent uses.
XLAYER_RPC_URL=https://rpc.xlayer.tech
XLAYER_TESTNET_RPC_URL=https://testrpc.xlayer.tech

# 196 = mainnet, 1952 = testnet. Defaults to 196.
CHAIN_ID=196

# --- OKLink Explorer verification ---------------------------------------
OKLINK_API_KEY=

# --- AI brains -----------------------------------------------------------
OPENAI_API_KEY=

# --- Token addresses on X Layer mainnet ---------------------------------
# These are used by the off-chain agent for OnchainOS `swap execute` calls.
# USDT is the dominant stablecoin on X Layer — `onchainos defi search` shows
# 4 live V3 pools for USDT and 0 for USDC. YieldAgent's swap-based rebalance
# path defaults to USDT as the quote (stable) side.
WOKB_ADDRESS=0xe538905cf8410324e03a5a23c1c177a474d59b2b
USDT_ADDRESS=0x779ded0c9e1022225f8e0630b35a9b54be713736
USDC_ADDRESS=0x74b7f16337b8972027f6196a17a631ac6de26d22
WETH_ADDRESS=0x5a77f1443d16ee5461801882a092c8620b8c4d58

# --- YieldAgent v2 deployment (auto-filled by scripts/deploy.ts) --------
# Real DEX execution uses OnchainOS — these are audit/registry contracts only.
STRATEGY_MANAGER_ADDRESS=
DECISION_LOGGER_ADDRESS=
FOLLOW_VAULT_FACTORY_ADDRESS=

# --- OnchainOS execution layer ------------------------------------------
# Every DEX transaction flows through OnchainOS — required for the
# "Most Active On-Chain Agent" prize's anti-gaming rule.
#
# The `onchainos` CLI (v2.2.7) reads these three env var names verbatim
# at `wallet login --force` time. Get your credentials from
#   https://web3.okx.com/onchainos/dev-portal
# All three are required for API-Key (AK) login. If you don't have a
# passphrase, use email login instead:
#   onchainos wallet login <your-email>
OKX_ACCESS_KEY=
OKX_SECRET_KEY=
OKX_PASSPHRASE=

# OnchainOS Agentic Wallet — auto-populated after `onchainos wallet login --force`.
# Run `onchainos wallet addresses` to find the X Layer (chainIndex 196) address.
# This is the address that signs every DEX tx inside the OnchainOS TEE via
# ERC-4337 bundling through EntryPoint v0.7.
# It is DIFFERENT from AGENT_ADDRESS above — AGENT_ADDRESS signs X Layer
# audit/registry txs (deployStrategy, recordExecution, logDecision), while
# ONCHAINOS_WALLET_ADDRESS is the source EOA carried in the userOp calldata
# for every `onchainos swap execute` the agent dispatches (see
# `OnchainOSAdapter.swap()`). Both wallets need OKB for gas on X Layer mainnet.
# ACCOUNT_ID is the OnchainOS account UUID; the CLI can drift between
# accounts on stale sessions, so pinning this lets `ensureLogin()` call
# `wallet switch <ACCOUNT_ID>` and force the funded account back up.
ONCHAINOS_WALLET_ADDRESS=
ONCHAINOS_ACCOUNT_ID=

# Optional: override the path to the onchainos binary (defaults to `onchainos`
# on PATH). Useful if the CLI is installed in a non-default location.
ONCHAINOS_CLI_PATH=

# Optional: force the OnchainOS adapter into simulate mode even when
# OKX_ACCESS_KEY is set. When true, no real DEX txs will be broadcast —
# useful for running the monitoring loop dry or for deterministic CI.
# Accepts "true" / "1". Default: auto (simulate when OKX_ACCESS_KEY is empty).
ONCHAINOS_SIMULATE=

# --- Agent backend -------------------------------------------------------
PORT=3001
